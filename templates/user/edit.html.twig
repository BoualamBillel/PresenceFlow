{% extends 'admin_base.html.twig' %}

{% block title %}Modifier l'Utilisateur - Administration{% endblock %}
{% block header_title %}Modification{% endblock %}

{% block admin_content %}
    <div class="bg-white px-6 py-8 rounded-t-3xl sm:rounded-3xl shadow-sm border border-slate-200 min-h-[70vh]">
        
        <div class="w-12 h-1.5 bg-gray-200 rounded-full mx-auto mb-8"></div>

        <div class="mb-8 inline-block">
            <h2 class="text-xl font-black text-black tracking-tight mb-1">Modifier l'Utilisateur</h2>
            <div class="h-0.5 w-full bg-black"></div>
        </div>

        {{ include('user/_form.html.twig', {'button_label': 'Mettre à jour le profil'}) }}
        
        {# Zone de gestion du compte (Archivage / Suppression) #}
        <div class="mt-12 pt-6 border-t border-dashed border-slate-200">
            <p class="text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-3">Zone de gestion critique</p>
            
            <div class="space-y-3">
                <button type="button" class="w-full bg-white hover:bg-slate-50 text-slate-900 font-bold py-3.5 px-4 border border-slate-200 rounded-xl transition-all text-xs uppercase tracking-wider text-center">
                    {{ user.isArchived ? 'Désarchiver le compte' : 'Archiver l\'utilisateur' }}
                </button>

                {{ include('user/_delete_form.html.twig') }}
            </div>
        </div>
        
    </div>
    
    <div class="text-center mt-6">
        <a href="{{ path('app_user_index') }}" class="text-xs font-bold text-slate-500 hover:text-black uppercase tracking-wider">
            Annuler les modifications
        </a>
    </div>
{% endblock %}