{% extends 'base.html.twig' %}

{% block title %}Connexion - PresenceFlow{% endblock %}

{% block body %}
{# Conteneur principal : Centrage vertical et horizontal, fond très clair #}
<div class="min-h-screen flex items-center justify-center bg-slate-50 p-4 font-sans">
    
    {# La Card Principale : Largeur max définie, fond gris ardoise clair, bords très arrondis #}
    <div class="w-full max-w-md bg-slate-200 rounded-[2rem] shadow-lg p-8 sm:p-10">
        
        {# En-tête de la carte #}
        <div class="text-center mb-10">
            <h1 class="text-3xl font-black text-slate-900 uppercase tracking-wider">Bon retour</h1>
            <p class="text-sm text-slate-600 mt-2 font-medium">Connectez-vous à votre compte</p>
        </div>

        {# Le Formulaire #}
        <form method="post" class="space-y-6">
            
            {# Gestion des erreurs Symfony #}
            {% if error %}
                <div class="bg-red-100 border-l-4 border-red-500 text-red-700 p-4 rounded text-sm mb-6" role="alert">
                    {{ error.messageKey|trans(error.messageData, 'security') }}
                </div>
            {% endif %}

            {# Champ Email #}
            <div class="space-y-2">
                <label for="username" class="block text-xs font-bold text-slate-500 uppercase tracking-widest">Email</label>
                <input type="email" 
                       value="{{ last_username }}" 
                       name="_username" 
                       id="username" 
                       class="w-full px-4 py-3 rounded-xl border border-transparent focus:border-slate-400 focus:bg-white focus:ring-0 bg-slate-100 text-slate-900 transition-colors outline-none placeholder-slate-400" 
                       placeholder="jean.dupont@ecole.fr" 
                       autocomplete="email" 
                       required 
                       autofocus>
            </div>

            {# Champ Mot de Passe #}
            <div class="space-y-2">
                <label for="password" class="block text-xs font-bold text-slate-500 uppercase tracking-widest">Mot de passe</label>
                <input type="password" 
                       name="_password" 
                       id="password" 
                       class="w-full px-4 py-3 rounded-xl border border-transparent focus:border-slate-400 focus:bg-white focus:ring-0 bg-slate-100 text-slate-900 transition-colors outline-none placeholder-slate-400" 
                       placeholder="********" 
                       autocomplete="current-password" 
                       required>
            </div>

            {# Token CSRF (Le Pass Navigo du formulaire) #}
            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            {# Bouton de Soumission #}
            <button type="submit" class="w-full bg-black hover:bg-slate-800 text-white font-bold py-4 rounded-xl transition-colors duration-200 uppercase tracking-wider text-sm mt-8 shadow-md">
                Se connecter
            </button>
        </form>

        {# Footer #}
        <div class="mt-8 text-center">
            <p class="text-xs text-slate-500 leading-relaxed font-medium">
                Identifiants perdus ou compte inexistant ?<br>
                Veuillez contacter l'administration de l'école.
            </p>
        </div>
        
    </div>
</div>
{% endblock %}