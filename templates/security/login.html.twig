<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Connexion - PresenceFlow</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-50 font-sans antialiased">

    <div class="min-h-screen flex flex-col justify-center py-6 sm:py-12 px-4 sm:px-6 lg:px-8 relative overflow-hidden">
        
        {# --- DÉCORATION DE FOND --- #}
        <div class="hidden sm:block absolute -top-24 -left-24 w-96 h-96 bg-slate-200 rounded-full mix-blend-multiply filter blur-3xl opacity-50 pointer-events-none"></div>
        <div class="hidden sm:block absolute top-48 -right-24 w-96 h-96 bg-slate-300 rounded-full mix-blend-multiply filter blur-3xl opacity-30 pointer-events-none"></div>

        {# --- HEADER & LOGO --- #}
        <div class="mx-auto w-full max-w-md text-center relative z-10 mb-6 sm:mb-8">
            <div class="mx-auto h-12 w-12 sm:h-14 sm:w-14 bg-black rounded-2xl flex items-center justify-center shadow-xl transform -rotate-3 transition-transform hover:rotate-0 duration-300">
                <svg class="w-6 h-6 sm:w-8 sm:h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
                </svg>
            </div>
            <h2 class="mt-4 sm:mt-6 text-2xl sm:text-3xl font-black text-slate-900 tracking-tight">PresenceFlow</h2>
            <p class="mt-1 sm:mt-2 text-xs sm:text-sm text-slate-500 font-medium">Gestion des présences & émargements</p>
        </div>

        {# --- CARTE DU FORMULAIRE --- #}
        <div class="mx-auto w-full max-w-md relative z-10">
            <div class="bg-white py-6 px-5 sm:py-8 sm:px-10 shadow-xl shadow-slate-200/50 rounded-2xl sm:rounded-3xl border border-slate-100">
                
                <form method="post" class="space-y-5 sm:space-y-6">
                    
                    {% if error %}
                        <div class="bg-red-50 border border-red-200 text-red-600 p-4 rounded-xl text-sm mb-6 flex items-start" role="alert">
                            <svg class="w-5 h-5 mr-2.5 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
                            </svg>
                            <span class="font-medium">{{ error.messageKey|trans(error.messageData, 'security') }}</span>
                        </div>
                    {% endif %}

                    <div>
                        <label for="username" class="block text-[11px] font-bold text-slate-500 uppercase tracking-widest mb-1.5">Adresse Email</label>
                        <input type="email" value="{{ last_username }}" name="_username" id="username" class="w-full p-3 bg-slate-50 border border-slate-300 rounded-xl focus:ring-2 focus:ring-black focus:border-black outline-none text-base sm:text-sm text-slate-900 transition-all placeholder-slate-400" placeholder="prenom.nom@presenceflow.com" autocomplete="email" required autofocus>
                    </div>

                    <div>
                        <label for="password" class="block text-[11px] font-bold text-slate-500 uppercase tracking-widest mb-1.5">Mot de passe</label>
                        <div class="relative">
                            <input type="password" name="_password" id="password" class="w-full p-3 pr-10 bg-slate-50 border border-slate-300 rounded-xl focus:ring-2 focus:ring-black focus:border-black outline-none text-base sm:text-sm text-slate-900 transition-all placeholder-slate-400" placeholder="••••••••" autocomplete="current-password" required>
                            
                            <button type="button" id="togglePassword" class="absolute inset-y-0 right-0 pr-3 flex items-center text-slate-400 hover:text-slate-600 focus:outline-none transition-colors" title="Afficher/Masquer le mot de passe">
                                <svg id="eyeIcon" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
                                </svg>
                                <svg id="eyeSlashIcon" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l18 18"></path>
                                </svg>
                            </button>
                        </div>
                    </div>

                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                    <div class="pt-1">
                        <button type="submit" class="w-full bg-black hover:bg-slate-800 text-white font-bold py-3.5 sm:py-4 rounded-xl text-sm text-center shadow-lg hover:shadow-xl transition-all flex items-center justify-center space-x-2">
                            <span>Se connecter</span>
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                            </svg>
                        </button>
                    </div>
                </form>

            </div>
            
            <div class="mt-6 sm:mt-8 text-center">
                <p class="text-xs text-slate-500 leading-relaxed font-medium">
                    Identifiants perdus ou compte inexistant ?<br>
                    Veuillez contacter l'administration de l'école.
                </p>
            </div>
        </div>
        
    </div>

    {# --- SCRIPT DE BASCULE DU MOT DE PASSE --- #}
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const toggleBtn = document.getElementById('togglePassword');
            const passwordInput = document.getElementById('password');
            const eyeIcon = document.getElementById('eyeIcon');
            const eyeSlashIcon = document.getElementById('eyeSlashIcon');

            if (toggleBtn && passwordInput) {
                toggleBtn.addEventListener('click', function() {
                    // Basculer le type de l'input
                    const type = passwordInput.getAttribute('type') === 'password' ? 'text' : 'password';
                    passwordInput.setAttribute('type', type);
                    
                    // Inverser la visibilité des icônes
                    eyeIcon.classList.toggle('hidden');
                    eyeSlashIcon.classList.toggle('hidden');
                });
            }
        });
    </script>
</body>
</html>