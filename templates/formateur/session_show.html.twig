<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard Formateur - PresenceFlow</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 min-h-screen flex flex-col font-sans pb-20">

    <header class="bg-white border-b border-gray-200 px-4 py-4 flex justify-between items-center sticky top-0 z-10">
        <button class="text-gray-500 hover:text-black">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
        </button>
        <h1 class="text-sm font-black text-black">Vue d'ensemble</h1>
        <button class="text-gray-500 hover:text-black">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"></path></svg>
        </button>
    </header>

    <main class="flex-grow p-4">
        
        {% if not qr_code_uri %}
            <div class="h-full flex flex-col items-center justify-center mt-32 space-y-4">
                <p class="text-sm font-bold text-black text-center">
                    Votre prochain cours commence à {{ session.heureDebut|date('H:i') }} :
                </p>
                <h2 class="text-2xl font-black text-center text-black">{{ session.matiere.nom }}</h2>
                <p class="text-xs text-gray-500 uppercase tracking-wider">{{ session.classe.nom }}</p>
                
                <span class="inline-flex items-center px-3 py-1 rounded-full border border-gray-300 text-[10px] font-bold uppercase tracking-wider text-gray-600 mt-2">
                    <span class="w-2 h-2 rounded-full bg-red-500 mr-2"></span>
                    Session Inactive
                </span>

                <form method="post" action="{{ path('app_formateur_session_start', {'id': session.id}) }}" class="w-full max-w-sm mt-12">
                    <input type="hidden" name="_token" value="{{ csrf_token('start' ~ session.id) }}">
                    <button type="submit" class="w-full bg-gray-400 hover:bg-black text-white font-bold py-4 rounded-none text-xs uppercase tracking-widest transition-colors flex items-center justify-center space-x-2">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                        <span>Lancer la session</span>
                    </button>
                </form>
            </div>

        {% else %}
            <div class="text-center mb-6">
                <h2 class="text-2xl font-black text-black">{{ session.classe.nom }}</h2>
                <p class="text-xs text-gray-500 uppercase tracking-wider">{{ session.matiere.nom }}</p>
                <span class="inline-flex items-center px-3 py-1 rounded-full border border-green-300 text-[10px] font-bold uppercase tracking-wider text-green-700 mt-2 bg-green-50">
                    <span class="w-2 h-2 rounded-full bg-green-500 mr-2"></span>
                    Session Active
                </span>
            </div>

            <div class="bg-white border border-black p-4 mb-8">
                <img src="{{ qr_code_uri }}" alt="QR Code d'émargement" class="w-full max-w-[300px] mx-auto mb-4 border-4 border-black">
                
                <div class="text-center font-bold text-sm mb-4 flex items-center justify-center space-x-2">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    <span>Valide pendant <span id="countdown" class="text-black font-black" data-time="{{ time_left }}">00:00</span></span>
                </div>

                <div class="space-y-2">
                    <form method="post" action="{{ path('app_formateur_session_start', {'id': session.id}) }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('start' ~ session.id) }}">
                        <button type="submit" class="w-full bg-black hover:bg-gray-800 text-white font-bold py-3 text-xs uppercase tracking-widest flex items-center justify-center space-x-2">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg>
                            <span>Régénérer le code</span>
                        </button>
                    </form>
                    <button class="w-full bg-black hover:bg-gray-800 text-white font-bold py-3 text-xs uppercase tracking-widest flex items-center justify-center space-x-2">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path></svg>
                        <span>Partager</span>
                    </button>
                </div>
            </div>

            <div class="mb-8">
                <p class="text-[10px] font-bold text-center uppercase tracking-wider mb-2">Présence</p>
                <div class="w-full h-3 bg-white border border-black flex">
                    <div class="h-full bg-black" style="width: 75%;"></div>
                </div>
                <p class="text-[10px] text-center text-gray-500 font-bold mt-1">18 / 24 PRÉSENTS</p>
            </div>

            <div class="mb-4">
                <h3 class="text-xs font-bold text-gray-400 uppercase tracking-wider border-b border-gray-200 pb-2 mb-4">Liste des étudiants</h3>
                
                <div class="space-y-3">
                    <div class="flex items-center bg-white border border-gray-200 p-3">
                        <div class="w-8 h-8 rounded-full bg-blue-100 text-blue-800 text-[10px] font-black flex items-center justify-center mr-3">SD</div>
                        <div>
                            <p class="text-sm font-bold text-black leading-none">Sophie Dupont</p>
                            <p class="text-[9px] font-black text-green-600 uppercase mt-1">✔ Présent</p>
                        </div>
                    </div>
                </div>
            </div>

            <button class="w-full bg-red-600 hover:bg-red-700 text-white font-bold py-4 text-xs uppercase tracking-widest mt-4">
                Clôturer l'émargement
            </button>
        {% endif %}
    </main>

    <nav class="fixed bottom-0 w-full bg-white border-t border-gray-200 flex justify-around py-3 px-2 z-50">
        <a href="#" class="flex flex-col items-center text-black">
            <svg class="w-5 h-5 mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"></path></svg>
            <span class="text-[8px] font-black tracking-wider">DASHBOARD</span>
        </a>
        <a href="#" class="flex flex-col items-center text-gray-400">
            <svg class="w-5 h-5 mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
            <span class="text-[8px] font-black tracking-wider">PLANNING</span>
        </a>
        <a href="#" class="flex flex-col items-center text-gray-400">
            <svg class="w-5 h-5 mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path></svg>
            <span class="text-[8px] font-black tracking-wider">CLASSES</span>
        </a>
        <a href="#" class="flex flex-col items-center text-gray-400">
            <svg class="w-5 h-5 mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
            <span class="text-[8px] font-black tracking-wider">PROFIL</span>
        </a>
    </nav>

    {# LOGIQUE JAVASCRIPT DU CHRONOMÈTRE #}
    {% if qr_code_uri %}
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const countdownElement = document.getElementById('countdown');
            let timeLeft = parseInt(countdownElement.getAttribute('data-time'), 10);

            function updateDisplay() {
                const minutes = Math.floor(timeLeft / 60);
                const seconds = timeLeft % 60;
                countdownElement.textContent = 
                    String(minutes).padStart(2, '0') + ':' + 
                    String(seconds).padStart(2, '0');
            }

            const timer = setInterval(() => {
                if (timeLeft <= 0) {
                    clearInterval(timer);
                    // Dès que le temps est écoulé, on recharge la page.
                    // Si le formateur ne clique pas sur Régénérer, le jeton backend est de toute façon invalide.
                    window.location.reload();
                } else {
                    timeLeft--;
                    updateDisplay();
                }
            }, 1000);
            
            updateDisplay();
        });
    </script>
    {% endif %}
</body>
</html>