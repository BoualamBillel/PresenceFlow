{% extends 'formateur_base.html.twig' %}

{% block title %}Mes Classes - PresenceFlow
{% endblock %}

{% block page_title %}Mes classes
{% endblock %}

{% block body %}
	{% set seuil = 80 %}

	<main class="flex-grow p-4 lg:p-10 lg:max-w-5xl lg:mx-auto lg:w-full">
		<div class="space-y-6">

			<div>
				<div class="inline-block">
					<h1 class="text-xl font-black text-black tracking-tight mb-1">Mes Classes</h1>
					<div class="h-0.5 w-full bg-black"></div>
				</div>
				<p class="text-sm text-slate-500 mt-2">Suivez l'assiduité de vos groupes.</p>
			</div>

			<div class="space-y-4 lg:space-y-0 lg:grid lg:grid-cols-2 lg:gap-6">
				{% for classe in classes %}
					{% set stat = stats[classe.id]|default({'total': 0, 'presents': 0}) %}
					{% set taux = stat.total > 0 ? ((stat.presents / stat.total) * 100)|round : null %}
					{% set vigilance = taux is not null and taux < seuil %}
					{% set nbEtudiants = classe.etudiants|filter(e => not e.isArchived)|length %}

					<a href="{{ path('app_formateur_classes_show', {'id': classe.id}) }}" class="block border-2 border-black rounded-lg p-4 bg-white transition-all hover:shadow-md">
						<div class="flex items-start justify-between gap-3 mb-2">
							<div class="min-w-0">
								<h4 class="text-sm font-black text-slate-900 tracking-tight">{{ classe.nom }}</h4>
								<p class="text-xs text-slate-500 font-medium">{{ classe.annee }}
									-
									{{ classe.filiere.description }}</p>
							</div>
							<div class="flex items-center gap-2 shrink-0">
								<span class="text-2xl font-black {{ vigilance ? 'text-orange-500' : 'text-black' }}">{{ taux is not null ? taux ~ '%' : '—' }}</span>
								<svg class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor" viewbox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
								</svg>
							</div>
						</div>

						<div class="flex items-center gap-2 mb-3">
							{% if vigilance %}
								<span class="inline-flex items-center gap-1 text-[9px] font-black tracking-widest uppercase text-orange-500">
									<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewbox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
									</svg>
									Vigilance
								</span>
							{% else %}
								<span class="text-[9px] font-black tracking-widest uppercase text-slate-400">Assiduité moyenne</span>
							{% endif %}
							<span class="bg-slate-100 text-slate-600 text-[9px] font-bold px-2 py-0.5 rounded">{{ nbEtudiants }}
								étudiants</span>
						</div>

						<div class="w-full h-2 bg-white border border-black flex">
							<div class="h-full {{ vigilance ? 'bg-orange-400' : 'bg-black' }}" style="width: {{ taux|default(0) }}%;"></div>
						</div>
					</a>
				{% else %}
					<div class="p-8 text-center border-2 border-dashed border-slate-300 rounded-lg bg-gray-50 lg:col-span-full">
						<p class="text-sm font-medium text-slate-500">Aucune classe rattachée à vos sessions pour le moment.</p>
					</div>
				{% endfor %}
			</div>

		</div>
	</main>
{% endblock %}
