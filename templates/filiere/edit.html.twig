{% extends 'admin_base.html.twig' %}

{% block title %}Modifier la Filière - Administration{% endblock %}
{% block header_title %}Modifier la filière{% endblock %}

{% block admin_content %}
    <div class="bg-white rounded-lg shadow-sm border border-slate-200 p-6 lg:p-8">

        <p class="text-sm text-slate-500 mb-8">
            Modifiez les informations de la filière <span class="font-semibold text-slate-700">{{ filiere.nom }}</span> puis enregistrez vos changements.
        </p>

        {{ include('filiere/_form.html.twig', {'button_label': 'Enregistrer les modifications'}) }}

        <div class="mt-10 pt-6 border-t border-slate-200">
            {{ include('filiere/_delete_form.html.twig') }}
        </div>

    </div>

    <div class="text-center mt-6">
        <a href="{{ path('app_filiere_index') }}" class="text-xs font-bold text-slate-500 hover:text-black uppercase tracking-wider transition-colors">
            Annuler et retourner à la liste
        </a>
    </div>
{% endblock %}