{% extends 'admin_base.html.twig' %}

{% block title %}Modifier la Filière - Administration{% endblock %}
{% block header_title %}Modification{% endblock %}

{% block admin_content %}
    <div class="bg-white px-6 py-8 rounded-t-3xl sm:rounded-3xl shadow-sm border border-slate-200">
        
        <div class="w-12 h-1.5 bg-gray-200 rounded-full mx-auto mb-8"></div>

        <div class="mb-8 inline-block">
            <h2 class="text-xl font-black text-black tracking-tight mb-1">Modifier la Filière</h2>
            <div class="h-0.5 w-full bg-black"></div>
        </div>

        {{ include('filiere/_form.html.twig', {'button_label': 'Enregistrer les modifications'}) }}
        
        <div class="mt-12 pt-6 border-t border-dashed border-slate-200">
            {{ include('filiere/_delete_form.html.twig') }}
        </div>
        
    </div>
    
    <div class="text-center mt-6">
        <a href="{{ path('app_filiere_index') }}" class="text-xs font-bold text-slate-500 hover:text-black uppercase tracking-wider">
            Annuler et retourner à la liste
        </a>
    </div>
{% endblock %}