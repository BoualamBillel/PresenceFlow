{{ form_start(form, {'attr': {'class': 'space-y-5', 'novalidate': 'novalidate'}}) }}

    {# Champ Nom #}
    <div>
        {{ form_label(form.nom, 'Nom de la filière', {'label_attr': {'class': 'block text-[10px] font-bold text-black uppercase tracking-wider mb-1'}}) }}
        {{ form_widget(form.nom, {'attr': {'class': 'w-full px-3 py-3 border border-gray-400 bg-white text-black focus:outline-none focus:border-black text-sm rounded-none', 'placeholder': 'Ex : CDA'}}) }}
        <div class="text-red-500 text-xs font-bold mt-1">{{ form_errors(form.nom) }}</div>
    </div>

    {# Champ Description #}
    <div>
        {{ form_label(form.description, 'Description', {'label_attr': {'class': 'block text-[10px] font-bold text-black uppercase tracking-wider mb-1'}}) }}
        {{ form_widget(form.description, {'attr': {'class': 'w-full px-3 py-3 border border-gray-400 bg-white text-black focus:outline-none focus:border-black text-sm rounded-none', 'placeholder': "ex: Concepteur Développeur d'Applications"}}) }}
        <div class="text-red-500 text-xs font-bold mt-1">{{ form_errors(form.description) }}</div>
    </div>

    {# Champ Niveau (Select) #}
    <div>
        {{ form_label(form.niveau, 'Niveau', {'label_attr': {'class': 'block text-[10px] font-bold text-black uppercase tracking-wider mb-1'}}) }}
        {{ form_widget(form.niveau, {'attr': {'class': 'w-full px-3 py-3 border border-gray-400 bg-white text-black focus:outline-none focus:border-black text-sm rounded-none appearance-none'}}) }}
        <div class="text-red-500 text-xs font-bold mt-1">{{ form_errors(form.niveau) }}</div>
    </div>

    {# Ligne de séparation de la maquette #}
    <hr class="border-gray-200 mt-8 mb-6">

    {# Bouton de Soumission #}
    <button type="submit" class="w-full bg-[#0a0a0a] hover:bg-black text-white font-bold py-4 rounded-lg transition-colors text-sm">
        {{ button_label|default('Créer la filière') }}
    </button>

{{ form_end(form) }}