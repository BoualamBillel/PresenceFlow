{{ form_start(form, {'attr': {'class': 'space-y-5', 'novalidate': 'novalidate'}}) }}

<div>
	{{ form_label(form.nom, 'Nom de la filière', {'label_attr': {'class': 'block text-[11px] font-bold text-slate-500 uppercase tracking-wider mb-1.5'}}) }}
	{{ form_widget(form.nom, {'attr': {'class': 'w-full px-4 py-2.5 border border-slate-300 bg-white text-black text-sm rounded-lg focus:outline-none focus:border-black transition-colors', 'placeholder': 'Ex : CDA'}}) }}
	<div class="text-red-500 text-xs font-bold mt-1">{{ form_errors(form.nom) }}</div>
</div>

<div>
	{{ form_label(form.description, 'Description', {'label_attr': {'class': 'block text-[11px] font-bold text-slate-500 uppercase tracking-wider mb-1.5'}}) }}
	{{ form_widget(form.description, {'attr': {'class': 'w-full px-4 py-2.5 border border-slate-300 bg-white text-black text-sm rounded-lg focus:outline-none focus:border-black transition-colors', 'placeholder': "Ex : Concepteur Développeur d'Applications"}}) }}
	<div class="text-red-500 text-xs font-bold mt-1">{{ form_errors(form.description) }}</div>
</div>

<div>
	{{ form_label(form.niveau, 'Niveau', {'label_attr': {'class': 'block text-[11px] font-bold text-slate-500 uppercase tracking-wider mb-1.5'}}) }}
	<div class="relative">
		{{ form_widget(form.niveau, {'attr': {'class': 'w-full px-4 py-2.5 pr-10 border border-slate-300 bg-white text-black text-sm rounded-lg focus:outline-none focus:border-black transition-colors appearance-none'}}) }}
		<svg class="w-4 h-4 text-slate-400 absolute right-3 top-1/2 -translate-y-1/2 pointer-events-none" fill="none" stroke="currentColor" stroke-width="2" viewbox="0 0 24 24">
			<path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
		</svg>
	</div>
	<div class="text-red-500 text-xs font-bold mt-1">{{ form_errors(form.niveau) }}</div>
</div>

<button type="submit" class="w-full bg-black hover:bg-slate-800 text-white font-bold py-3 rounded-lg transition-colors text-sm mt-2">
	{{ button_label|default('Créer la filière') }}
</button>

{{ form_end(form) }}
