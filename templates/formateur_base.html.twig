<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Espace Formateur - PresenceFlow{% endblock %}</title>
    <script src="https://cdn.tailwindcss.com"></script>
    {% block stylesheets %}{% endblock %}
</head>
<body class="bg-gray-50 min-h-screen flex flex-col font-sans pb-20 lg:pb-0">

    {% set current_route = app.request.attributes.get('_route') %}

    {# --- SIDEBAR (desktop uniquement, la bottom nav prend le relais sur mobile) --- #}
    <aside class="hidden lg:flex fixed inset-y-0 left-0 w-72 bg-white border-r border-gray-200 z-40 flex-col">
        <div class="p-6 border-b border-gray-100">
            <h2 class="text-2xl font-black text-black tracking-tight">Espace Formateur</h2>
        </div>

        <nav class="flex-1 p-4 space-y-2 mt-4">
            <a href="#"
                class="flex items-center space-x-4 px-4 py-3 rounded-lg transition-colors {{ current_route == 'app_formateur_dashboard' ? 'text-black font-bold bg-gray-100' : 'text-gray-500 font-semibold hover:bg-gray-50' }}">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"></path>
                </svg>
                <span>DASHBOARD</span>
            </a>

            <a href="#"
                class="flex items-center space-x-4 px-4 py-3 rounded-lg transition-colors {{ current_route == 'app_formateur_planning' ? 'text-black font-bold bg-gray-100' : 'text-gray-500 font-semibold hover:bg-gray-50' }}">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                </svg>
                <span>PLANNING</span>
            </a>

            <a href="#"
                class="flex items-center space-x-4 px-4 py-3 rounded-lg transition-colors {{ current_route == 'app_formateur_classes' ? 'text-black font-bold bg-gray-100' : 'text-gray-500 font-semibold hover:bg-gray-50' }}">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
                </svg>
                <span>CLASSES</span>
            </a>

            <a href="#"
                class="flex items-center space-x-4 px-4 py-3 rounded-lg transition-colors {{ current_route == 'app_formateur_profil' ? 'text-black font-bold bg-gray-100' : 'text-gray-500 font-semibold hover:bg-gray-50' }}">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                </svg>
                <span>PROFIL</span>
            </a>
        </nav>
    </aside>

    <header class="bg-white border-b border-gray-200 px-4 lg:px-10 lg:pl-80 py-4 flex justify-between items-center sticky top-0 z-10">
        <div class="w-6 lg:hidden"></div>

        <h1 class="text-sm font-black text-black uppercase tracking-wider">
            {% block page_title %}Vue d'ensemble{% endblock %}
        </h1>

        <a href="{{ path('app_logout') }}" class="text-slate-800 hover:text-red-600 transition-colors duration-200" title="Se déconnecter">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path>
            </svg>
        </a>
    </header>

    <div class="lg:pl-72 px-4 lg:px-10 pt-4">
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="max-w-5xl mx-auto p-4 mb-2 text-xs font-bold text-white uppercase tracking-widest text-center rounded-lg shadow-sm {{ label == 'success' ? 'bg-[#16a34a]' : (label == 'error' ? 'bg-red-600' : 'bg-black') }}">
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}
    </div>

    <div class="flex-grow flex flex-col lg:pl-72">
        {% block body %}{% endblock %}
    </div>

    {# --- BOTTOM NAV (mobile uniquement) --- #}
    <nav class="fixed bottom-0 w-full bg-white border-t border-gray-200 flex justify-around py-3 px-2 z-50 lg:hidden">
        <a href="#" class="flex flex-col items-center transition-colors {{ current_route == 'app_formateur_dashboard' ? 'text-black' : 'text-gray-400 hover:text-black' }}">
            <svg class="w-5 h-5 mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"></path></svg>
            <span class="text-[8px] font-black tracking-wider">DASHBOARD</span>
        </a>

        <a href="#" class="flex flex-col items-center transition-colors {{ current_route == 'app_formateur_planning' ? 'text-black' : 'text-gray-400 hover:text-black' }}">
            <svg class="w-5 h-5 mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
            <span class="text-[8px] font-black tracking-wider">PLANNING</span>
        </a>

        <a href="#" class="flex flex-col items-center transition-colors {{ current_route == 'app_formateur_classes' ? 'text-black' : 'text-gray-400 hover:text-black' }}">
            <svg class="w-5 h-5 mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path></svg>
            <span class="text-[8px] font-black tracking-wider">CLASSES</span>
        </a>

        <a href="#" class="flex flex-col items-center transition-colors {{ current_route == 'app_formateur_profil' ? 'text-black' : 'text-gray-400 hover:text-black' }}">
            <svg class="w-5 h-5 mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
            <span class="text-[8px] font-black tracking-wider">PROFIL</span>
        </a>
    </nav>

    {% block javascripts %}{% endblock %}
</body>
</html>