{% extends 'admin_base.html.twig' %}

{% block title %}{{ classe.nom }} - Administration{% endblock %}
{% block header_title %}Classes{% endblock %}

{% block admin_content %}
    <div class="space-y-6 bg-white min-h-[70vh]">
        
        <div class="relative flex items-center justify-center pt-2 mb-6">
            <a href="{{ path('app_classe_index') }}" class="absolute left-0 text-black hover:text-gray-600 transition-colors p-2">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
            </a>
            <div class="text-center">
                <h2 class="text-xl font-black text-black tracking-tight">{{ classe.nom|upper }}</h2>
                <p class="text-xs text-gray-500 font-medium mt-1">{{ classe.annee }} - {{ classe.filiere ? classe.filiere.nom : 'Sans filière' }}</p>
            </div>
        </div>

        <a href="{{ path('app_classe_show', {'id': classe.id}) }}" class="w-full bg-black hover:bg-slate-800 text-white font-bold py-3.5 rounded-none text-xs tracking-widest transition-colors uppercase flex items-center justify-center space-x-3">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"></path></svg>
            <span>+ AJOUTER DES ÉTUDIANTS</span>
        </a>

        <div class="border border-black rounded-xl p-4 flex items-center justify-center space-x-4">
            <svg class="w-6 h-6 text-black" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
            <div>
                <p class="text-[10px] font-bold text-gray-500 uppercase tracking-wider">Effectif</p>
                <p class="text-sm font-black text-black">{{ classe.etudiants|length }} étudiants inscrits</p>
            </div>
        </div>

        <div class="mt-8 mb-4">
            <h3 class="text-lg font-bold text-black mb-2">Liste des Étudiants</h3>
            <hr class="border-gray-300">
        </div>

        <div class="border border-gray-200 bg-white">
            {% for etudiant in classe.etudiants %}
                <div class="flex items-center justify-between p-4 border-b border-gray-200 last:border-b-0 hover:bg-gray-50 transition-colors">
                    
                    <div class="flex items-center space-x-4">
                        <div class="w-10 h-10 rounded-xl flex items-center justify-center font-bold text-xs bg-blue-100 text-blue-800">
                            {{ etudiant.prenom|first|upper }}{{ etudiant.nom|first|upper }}
                        </div>
                        
                        <h3 class="text-sm font-bold text-gray-900">{{ etudiant.prenom }} {{ etudiant.nom }}</h3>
                    </div>
                    
                    <form method="post" action="{{ path('app_classe_remove_student', {'id': classe.id, 'studentId': etudiant.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir retirer cet étudiant de la classe ?');">
                        <input type="hidden" name="_token" value="{{ csrf_token('remove' ~ etudiant.id) }}">
                        <button type="submit" class="text-gray-400 hover:text-red-500 transition-colors p-2">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                        </button>
                    </form>

                </div>
            {% else %}
                <div class="p-8 text-center text-sm font-medium text-slate-500">
                    Aucun étudiant dans cette classe pour le moment.
                </div>
            {% endfor %}
        </div>

        {% if classe.etudiants|length > 0 %}
            <div class="text-center pt-4 pb-8">
                <button type="button" class="text-[10px] font-bold text-slate-500 hover:text-black transition-colors uppercase tracking-wider">
                    Charger plus d'utilisateurs
                </button>
            </div>
        {% endif %}

    </div>
{% endblock %}