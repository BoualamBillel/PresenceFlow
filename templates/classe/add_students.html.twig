{% extends 'admin_base.html.twig' %}

{% block title %}Ajouter des étudiants - {{ classe.nom }}{% endblock %}
{% block header_title %}Classes{% endblock %}

{% block admin_content %}
    <div class="bg-white min-h-[80vh] flex flex-col relative pb-24">
        
        <div class="relative flex items-center justify-center pt-2 mb-8">
            <a href="{{ path('app_classe_show', {'id': classe.id}) }}" class="absolute left-0 text-black hover:text-gray-600 p-2">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
            </a>
            <h2 class="text-xl font-black text-black tracking-tight underline decoration-2 underline-offset-4">Ajouter des étudiants</h2>
        </div>

        <form method="get" action="{{ path('app_classe_add_students', {'id': classe.id}) }}" class="mb-4 px-4">
            <div class="relative">
                <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                    <svg class="w-5 h-5 text-black" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                </div>
                <input type="text" name="q" value="{{ search_term }}" 
                       class="w-full pl-10 pr-4 py-3 border border-black focus:outline-none text-sm font-medium text-black placeholder-gray-500 rounded-none" 
                       placeholder="RECHERCHER PAR NOM, EMAIL..."
                       onchange="this.form.submit()">
            </div>
        </form>

        <form method="post" action="{{ path('app_classe_add_students', {'id': classe.id}) }}" id="add-students-form" class="flex-1">
            
            <div class="border-t border-black">
                {% for student in students %}
                    <label class="flex items-center p-4 border-b border-black hover:bg-gray-50 cursor-pointer transition-colors group">
                        
                        <div class="relative flex items-center justify-center mr-4">
                            <input type="checkbox" name="students[]" value="{{ student.id }}" class="peer sr-only student-checkbox">
                            <div class="w-5 h-5 border-2 border-black bg-white peer-checked:bg-blue-600 peer-checked:border-blue-600 transition-colors flex items-center justify-center">
                                <svg class="w-3 h-3 text-white opacity-0 peer-checked:opacity-100" fill="none" stroke="currentColor" stroke-width="4" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path></svg>
                            </div>
                        </div>

                        <div class="w-8 h-8 rounded-full flex items-center justify-center font-bold text-[10px] bg-blue-100 text-blue-800 mr-4">
                            {{ student.prenom|first|upper }}{{ student.nom|first|upper }}
                        </div>
                        
                        <span class="text-sm font-bold text-gray-900">{{ student.prenom }} {{ student.nom }}</span>
                    </label>
                {% else %}
                    <div class="p-8 text-center text-sm font-medium text-slate-500">
                        Aucun étudiant disponible ou correspondant à la recherche.
                    </div>
                {% endfor %}
            </div>

            <div class="sticky bottom-0 p-4 bg-white border-t border-black mt-auto z-40 shadow-[0_-10px_15px_-3px_rgba(0,0,0,0.05)]">
                <button type="submit" id="submit-btn" disabled class="w-full bg-black hover:bg-slate-800 disabled:bg-gray-300 disabled:text-gray-500 text-white font-bold py-4 rounded-xl text-sm transition-colors flex items-center justify-center space-x-2">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"></path></svg>
                    <span id="btn-text">Ajouter (0) étudiant(s)</span>
                </button>
            </div>
        </form>

    </div>

    <script>
        document.addEventListener('turbo:load', () => {
            const checkboxes = document.querySelectorAll('.student-checkbox');
            const btnText = document.getElementById('btn-text');
            const submitBtn = document.getElementById('submit-btn');

            function updateCounter() {
                const count = document.querySelectorAll('.student-checkbox:checked').length;
                btnText.textContent = `Ajouter (${count}) étudiant(s)`;
                submitBtn.disabled = count === 0;
            }

            checkboxes.forEach(box => box.addEventListener('change', updateCounter));
            updateCounter(); // Init au chargement
        });
    </script>
{% endblock %}