{% extends 'admin_base.html.twig' %}

{% block title %}Étudiants - {{ classe.nom }}{% endblock %}
{% block header_title %}Classes{% endblock %}

{% block admin_content %}
    <div class="space-y-6 lg:max-w-6xl lg:mx-auto">

        <div>
            <p class="text-sm font-medium text-slate-700">
                Gérez les étudiants de <strong>{{ classe.nom }}</strong> — {{ classe.annee }}{% if classe.filiere %}, {{ classe.filiere.nom }}{% endif %}.
            </p>
        </div>

        <div class="lg:grid lg:grid-cols-2 lg:gap-10 lg:items-start">

            <div class="mb-10 lg:mb-0">
                <h3 class="text-xs font-bold text-slate-400 uppercase tracking-wider border-b border-slate-200 pb-2 mb-4 flex justify-between">
                    <span>Membres de la classe</span>
                    <span>{{ classe.etudiants|length }}</span>
                </h3>

                <div class="border border-slate-300 rounded-lg bg-white">
                    {% for etudiant in classe.etudiants %}
                        <div class="flex items-center justify-between p-4 border-b border-slate-200 last:border-b-0">
                            <div class="flex items-center space-x-3">
                                <div class="w-8 h-8 rounded-full flex items-center justify-center font-bold text-[10px] bg-blue-100 text-blue-800">
                                    {{ etudiant.prenom|first|upper }}{{ etudiant.nom|first|upper }}
                                </div>
                                <span class="text-sm font-bold text-slate-900">{{ etudiant.prenom }} {{ etudiant.nom }}</span>
                            </div>
                            <form method="post" action="{{ path('app_classe_remove_student', {'id': classe.id, 'studentId': etudiant.id}) }}">
                                <input type="hidden" name="_token" value="{{ csrf_token('classe_remove_student' ~ etudiant.id) }}">
                                <button type="submit" title="Retirer de la classe"
                                        class="p-1.5 border border-slate-300 rounded text-slate-500 transition-all duration-200 hover:bg-red-50 hover:text-red-600 hover:border-red-300">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                                </button>
                            </form>
                        </div>
                    {% else %}
                        <div class="p-8 text-center text-sm font-medium text-slate-500">
                            Aucun étudiant dans cette classe pour le moment.
                        </div>
                    {% endfor %}
                </div>
            </div>

            <div>
                <h3 class="text-xs font-bold text-slate-400 uppercase tracking-wider border-b border-slate-200 pb-2 mb-4">
                    <span>Ajouter des étudiants</span>
                </h3>

                <form method="get" action="{{ path('app_classe_add_students', {'id': classe.id}) }}" class="mb-4">
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <svg class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                        </div>
                        <input type="text" name="q" value="{{ search_term }}"
                               class="w-full pl-10 pr-4 py-3 border border-slate-300 rounded-lg text-sm font-medium text-slate-900 placeholder-slate-500 focus:outline-none focus:border-black"
                               placeholder="RECHERCHER PAR NOM, EMAIL..."
                               onchange="this.form.submit()">
                    </div>
                </form>

                <form method="post" action="{{ path('app_classe_add_students', {'id': classe.id}) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('classe_add_students' ~ classe.id) }}">

                    <div class="border border-slate-300 rounded-lg bg-white max-h-96 overflow-y-auto">
                        {% for student in etudiants %}
                            <label class="flex items-center p-4 border-b border-slate-200 last:border-b-0 hover:bg-slate-50 cursor-pointer transition-colors">

                                <div class="relative flex items-center justify-center mr-3">
                                    <input type="checkbox" name="students[]" value="{{ student.id }}" class="peer sr-only student-checkbox">
                                    <div class="w-5 h-5 border-2 border-slate-300 rounded-md bg-white transition-colors peer-checked:bg-black peer-checked:border-black flex items-center justify-center">
                                        <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>
                                    </div>
                                </div>

                                <div class="w-8 h-8 rounded-full flex items-center justify-center font-bold text-[10px] bg-blue-100 text-blue-800 mr-3">
                                    {{ student.prenom|first|upper }}{{ student.nom|first|upper }}
                                </div>

                                <div>
                                    <p class="text-sm font-bold text-slate-900 leading-tight">{{ student.prenom }} {{ student.nom }}</p>
                                    <p class="text-xs text-slate-500">{{ student.email }}</p>
                                </div>
                            </label>
                        {% else %}
                            <div class="p-8 text-center text-sm font-medium text-slate-500">
                                Aucun étudiant disponible ou correspondant à la recherche.
                            </div>
                        {% endfor %}
                    </div>

                    <div class="sticky bottom-4 lg:static mt-4">
                        <button type="submit" id="submit-btn" disabled
                                class="w-full bg-black hover:bg-slate-800 disabled:bg-slate-300 disabled:text-slate-500 disabled:cursor-not-allowed text-white font-bold py-3.5 rounded-lg text-xs tracking-widest uppercase transition-colors flex items-center justify-center space-x-3">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"></path></svg>
                            <span id="btn-text">Ajouter (0) étudiant(s)</span>
                        </button>
                    </div>
                </form>
            </div>

        </div>

        <div class="pt-2 pb-4">
            <a href="{{ path('app_classe_index') }}" class="text-xs font-bold text-slate-500 hover:text-black uppercase tracking-wider">
                ← Retour aux classes
            </a>
        </div>

    </div>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const btnText = document.getElementById('btn-text');
            const submitBtn = document.getElementById('submit-btn');

            function updateCounter() {
                const count = document.querySelectorAll('.student-checkbox:checked').length;
                btnText.textContent = `Ajouter (${count}) étudiant(s)`;
                submitBtn.disabled = count === 0;
            }

            document.querySelectorAll('.student-checkbox').forEach(box => box.addEventListener('change', updateCounter));
            updateCounter();
        });
    </script>
{% endblock %}