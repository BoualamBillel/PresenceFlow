{% extends 'admin_base.html.twig' %}

{% block title %}Classes - Administration{% endblock %}
{% block header_title %}Classes{% endblock %}

{% block admin_content %}
    
    <div class="space-y-6 lg:max-w-6xl lg:mx-auto">
        
        <div>
            <p class="text-sm font-medium text-slate-700">Gérez les classes de votre établissement.</p>
        </div>

        <form method="get" action="{{ path('app_classe_index') }}" id="filter-form" class="space-y-4">
            
            <div class="space-y-4 lg:space-y-0 lg:flex lg:gap-4 lg:items-center">
                <div class="relative lg:flex-1">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                        <svg class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                    </div>
                    <input type="text" name="q" value="{{ search_term }}" 
                           class="w-full pl-10 pr-4 py-3 border border-slate-300 focus:border-black focus:outline-none text-sm font-medium text-slate-900 placeholder-slate-500 rounded-lg" 
                           placeholder="RECHERCHER UNE CLASSE (EX: DWWM, CDA)">
                </div>

                <div class="flex justify-center mb-2 lg:mb-0 lg:shrink-0">
                    <div class="inline-flex rounded-lg border border-black p-0.5 w-64 bg-gray-200">
                        <input type="hidden" name="filter" id="filter-input" value="{{ current_filter }}">
                        
                        <button type="button" onclick="document.getElementById('filter-input').value='actives'; document.getElementById('filter-form').submit();" 
                                class="flex-1 py-1.5 text-xs font-bold transition-all rounded-md {{ current_filter == 'actives' ? 'bg-[#1a1a1a] text-white shadow' : 'text-gray-700 hover:text-black' }}">
                            Actives
                        </button>
                        
                        <button type="button" onclick="document.getElementById('filter-input').value='archivees'; document.getElementById('filter-form').submit();" 
                                class="flex-1 py-1.5 text-xs font-bold transition-all rounded-md {{ current_filter == 'archivees' ? 'bg-[#1a1a1a] text-white shadow' : 'text-gray-700 hover:text-black' }}">
                            Archivées
                        </button>
                    </div>
                </div>

                <a href="{{ path('app_classe_new') }}" class="block w-full text-center bg-black hover:bg-slate-800 text-white font-bold py-3.5 rounded-lg text-xs tracking-widest transition-colors uppercase flex items-center justify-center space-x-3 lg:w-auto lg:px-10 lg:shrink-0">
                    <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm5 11h-4v4h-2v-4H7v-2h4V7h2v4h4v2z"/></svg>
                    <span>NOUVELLE CLASSE</span>
                </a>
            </div>

        </form>

        <div class="space-y-4 mt-6 lg:mt-0 lg:space-y-0 lg:grid lg:grid-cols-2 xl:grid-cols-3 lg:gap-6">
            {% for classe in classes %}
                <a href="{{ path('app_classe_add_students', {'id': classe.id}) }}" class="block border border-slate-300 rounded-lg p-4 hover:shadow-md transition-shadow bg-white group">
                    <div class="flex justify-between items-center">
                        
                        <div>
                            <h3 class="text-sm font-black text-slate-900 tracking-wide">{{ classe.nom|upper }}</h3>
                            <p class="text-xs text-slate-500 mt-1">
                                {{ classe.annee }} - {{ classe.filiere ? classe.filiere.nom : 'Sans filière' }}
                            </p>
                            
                            <div class="mt-3 inline-block bg-slate-100 border border-slate-200 text-slate-700 px-3 py-1 rounded-full text-[10px] font-bold">
                                {{ classe.etudiants|length }} étudiants
                            </div>
                        </div>

                        <div class="text-slate-400 group-hover:text-black transition-colors">
                            <svg class="w-6 h-6 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                        </div>
                        
                    </div>
                </a>
            {% else %}
                <div class="p-8 text-center border border-dashed border-slate-300 rounded-lg lg:col-span-full">
                    <p class="text-sm font-medium text-slate-500">Aucune classe trouvée.</p>
                </div>
            {% endfor %}
        </div>

    </div>

{% endblock %}