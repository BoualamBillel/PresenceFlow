{% extends 'admin_base.html.twig' %}

{% block title %}Export CSV - Administration{% endblock %}
{% block header_title %}Exporter les présences{% endblock %}

{% block admin_content %}
    <div class="w-full max-w-xl mx-auto flex flex-col">
        
        <div class="mb-6 mt-2">
            <p class="text-sm font-medium text-slate-700">Sélectionnez une classe ou un élève précis pour cibler l'extraction.</p>
        </div>

        <div class="bg-white border border-slate-200 rounded-2xl p-5 sm:p-8 shadow-sm">
            {{ form_start(form, {
                'method': 'POST',
                'action': path('admin_export'),
                'attr': {
                    'class': 'space-y-6',
                    'data-turbo': 'false'
                }
            }) }}
                
                <div>
                    {{ form_label(form.classe, 'Exporter toute une classe', {'label_attr': {'class': 'block text-[11px] font-bold text-slate-500 uppercase tracking-widest mb-2'}}) }}
                    {{ form_widget(form.classe, {'attr': {'class': 'w-full p-3 bg-white border border-slate-300 rounded-lg focus:border-black focus:outline-none text-sm text-slate-900 transition-colors disabled:opacity-50 disabled:bg-slate-100 disabled:cursor-not-allowed'}}) }}
                </div>

                <div class="relative flex py-2 items-center">
                    <div class="flex-grow border-t border-slate-200"></div>
                    <span class="flex-shrink-0 mx-4 text-slate-400 text-xs font-bold uppercase tracking-widest">OU</span>
                    <div class="flex-grow border-t border-slate-200"></div>
                </div>

                <div>
                    {{ form_label(form.etudiant, 'Exporter un élève spécifique', {'label_attr': {'class': 'block text-[11px] font-bold text-slate-500 uppercase tracking-widest mb-2'}}) }}
                    {{ form_widget(form.etudiant, {'attr': {'class': 'w-full p-3 bg-white border border-slate-300 rounded-lg focus:border-black focus:outline-none text-sm text-slate-900 transition-all disabled:opacity-50 disabled:bg-slate-100 disabled:cursor-not-allowed'}}) }}
                </div>

                <div class="pt-6 mt-2">
                    <button type="submit" class="w-full bg-black text-white font-bold py-3.5 rounded-lg text-xs tracking-widest uppercase text-center hover:bg-slate-800 transition-colors flex items-center justify-center space-x-3">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
                        <span>Télécharger le CSV</span>
                    </button>
                </div>
                
            {{ form_end(form) }}
        </div>

    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const classeSelect = document.getElementById('export_filter_classe');
            const etudiantSelect = document.getElementById('export_filter_etudiant');
            if (!classeSelect || !etudiantSelect) return;

            function updateExclusivity() {
                if (classeSelect.value !== "") {
                    etudiantSelect.disabled = true;
                    etudiantSelect.value = ""; 
                } else {
                    etudiantSelect.disabled = false;
                }

                if (etudiantSelect.value !== "") {
                    classeSelect.disabled = true;
                    classeSelect.value = ""; 
                } else {
                    classeSelect.disabled = false;
                }
            }
            classeSelect.addEventListener('change', updateExclusivity);
            etudiantSelect.addEventListener('change', updateExclusivity);
            updateExclusivity();
        });
    </script>
{% endblock %}