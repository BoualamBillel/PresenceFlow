{% extends 'admin_base.html.twig' %}

{% block title %}Export CSV - Administration{% endblock %}
{% block header_title %}Exporter les présences{% endblock %}

{% block admin_content %}
    <div class="max-w-md mx-auto bg-white min-h-screen p-4 pb-24">
        
        <div class="mb-6">
            <h2 class="text-lg font-bold text-gray-900 mb-1">Générer un export</h2>
            <p class="text-sm text-gray-600">Sélectionnez une classe <span class="font-bold underline">OU</span> un élève. Ne sélectionnez rien pour un export global.</p>
        </div>

        <div class="border border-gray-200 rounded-lg p-5 bg-white shadow-sm">
            {{ form_start(form, {
                'method': 'POST',
                'action': path('admin_export'),
                'attr': {
                    'class': 'space-y-6',
                    'data-turbo': 'false'
                }
            }) }}
                
                <div>
                    {{ form_label(form.classe, 'Exporter toute une classe', {'label_attr': {'class': 'block text-xs font-bold text-gray-700 uppercase tracking-widest mb-2'}}) }}
                    {{ form_widget(form.classe, {'attr': {'class': 'w-full p-2.5 bg-gray-50 border border-gray-300 rounded-lg focus:ring-2 focus:ring-black focus:outline-none text-sm text-gray-800 transition-colors disabled:opacity-50 disabled:bg-gray-100 disabled:cursor-not-allowed'}}) }}
                </div>

                <div class="relative flex py-2 items-center">
                    <div class="flex-grow border-t border-gray-300"></div>
                    <span class="flex-shrink-0 mx-4 text-gray-400 text-xs font-bold uppercase tracking-widest">OU</span>
                    <div class="flex-grow border-t border-gray-300"></div>
                </div>

                <div>
                    {{ form_label(form.etudiant, 'Exporter un élève spécifique', {'label_attr': {'class': 'block text-xs font-bold text-gray-700 uppercase tracking-widest mb-2'}}) }}
                    {{ form_widget(form.etudiant, {'attr': {'class': 'w-full p-2.5 bg-gray-50 border border-gray-300 rounded-lg focus:ring-2 focus:ring-black focus:outline-none text-sm text-gray-800 transition-all disabled:opacity-50 disabled:bg-gray-100 disabled:cursor-not-allowed'}}) }}
                </div>

                <div class="pt-4 border-t border-gray-200">
                    <button type="submit" class="w-full bg-black text-white font-bold py-3.5 rounded-lg text-sm text-center shadow-md hover:bg-gray-800 transition-colors flex items-center justify-center space-x-2">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
                        <span>Télécharger le CSV</span>
                    </button>
                </div>
                
            {{ form_end(form) }}
        </div>

    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const classeSelect = document.getElementById('export_filter_classe');
            const etudiantSelect = document.getElementById('export_filter_etudiant');
            
            if (!classeSelect || !etudiantSelect) return;

            function updateExclusivity() {
                // Si une classe est choisie, on verrouille l'étudiant
                if (classeSelect.value !== "") {
                    etudiantSelect.disabled = true;
                    etudiantSelect.value = ""; // On s'assure qu'il est vide
                } else {
                    etudiantSelect.disabled = false;
                }

                // Si un étudiant est choisi, on verrouille la classe
                if (etudiantSelect.value !== "") {
                    classeSelect.disabled = true;
                    classeSelect.value = ""; // On s'assure qu'elle est vide
                } else {
                    classeSelect.disabled = false;
                }
            }

            classeSelect.addEventListener('change', updateExclusivity);
            etudiantSelect.addEventListener('change', updateExclusivity);

            updateExclusivity();
        });
    </script>
{% endblock %}