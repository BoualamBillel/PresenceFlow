{% extends 'admin_base.html.twig' %}

{% block title %}Vue d'ensemble - Administration{% endblock %}
{% block header_title %}Vue d'ensemble{% endblock %}

{% block admin_content %}
<div class="max-w-md lg:max-w-7xl mx-auto bg-white min-h-screen p-4 lg:p-8 pb-24 w-full">

    {# --- SECTION 1 : KPI CARDS --- #}
    <div class="space-y-4 mb-8 lg:space-y-0 lg:grid lg:grid-cols-3 lg:gap-6">

        {# Carte : Justificatifs #}
        <div class="border border-gray-200 rounded-lg p-5 bg-white shadow-sm flex justify-between items-start">
            <div>
                <p class="text-2xl font-bold text-red-500 mb-4">{{ count_justificatifs }}</p>
                <p class="text-[10px] font-bold text-gray-500 uppercase tracking-wider">Justificatifs en attente</p>
            </div>
            <div class="text-gray-800">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
            </div>
        </div>

        {# Carte : Sessions #}
        <div class="border border-gray-200 rounded-lg p-5 bg-white shadow-sm flex justify-between items-start">
            <div>
                <p class="text-2xl font-bold text-gray-900 mb-4">{{ count_sessions }}</p>
                <p class="text-[10px] font-bold text-gray-500 uppercase tracking-wider">Sessions aujourd'hui</p>
            </div>
            <div class="text-gray-800">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253">
                    </path>
                </svg>
            </div>
        </div>

        {# Carte : Présence #}
        <div class="border border-gray-200 rounded-lg p-5 bg-white shadow-sm flex justify-between items-start">
            <div>
                <p class="text-2xl font-bold text-gray-900 mb-4">{{ taux_presence }}%</p>
                <p class="text-[10px] font-bold text-gray-500 uppercase tracking-wider">Présence globale</p>
            </div>
            <div class="text-gray-800">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                </svg>
            </div>
        </div>

    </div>

    {# --- SECTION 2 : BOUTONS D'ACTION --- #}
    <div class="space-y-4 mb-10 lg:space-y-0 lg:grid lg:grid-cols-3 lg:gap-6">
        <a href="{{ path('admin_justificatif_index') }}"
            class="block w-full bg-black text-white font-bold py-3.5 rounded-lg text-sm text-center shadow-md hover:bg-gray-800 transition-colors flex items-center justify-center space-x-3">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10l6 6v10a2 2 0 01-2 2z"></path>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 13h6M9 17h3M14 2v6h6">
                </path>
            </svg>
            <span>Traiter les justificatifs</span>
        </a>

        {# Grille 2 boutons secondaires #}
        <div class="flex gap-4 lg:contents">
            <a href="{{ path('admin_export') }}"
                class="w-1/2 lg:w-auto flex items-center justify-center space-x-2 py-3 border border-gray-400 rounded-lg text-sm font-bold text-gray-900 hover:bg-gray-50">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
                </svg>
                <span>Générer un Export</span>
            </a>

            <a href="{{ path('app_session_cours_new') }}"
                class="w-1/2 lg:w-auto flex items-center justify-center space-x-2 py-3 border border-gray-400 rounded-lg text-sm font-bold text-gray-900 hover:bg-gray-50">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                </svg>
                <span>Nouvelle Session</span>
            </a>
        </div>
    </div>

    {# --- SECTION 3 : ACTIVITÉS RÉCENTES DYNAMIQUES --- #}
    <div>
        <h2 class="text-xl font-bold text-black mb-1">Activités récentes</h2>
        <div class="h-1 w-24 bg-black mb-6"></div>

        <div class="space-y-4 lg:space-y-0 lg:grid lg:grid-cols-2 lg:gap-4">
            {% for activite in activites %}
            <a href="{{ activite.route }}"
                class="block border border-gray-200 rounded-lg p-4 bg-white shadow-sm hover:shadow-md transition-shadow flex items-center justify-between group">
                <div class="flex items-start space-x-3">
                    <div class="w-3 h-3 rounded-full mt-1.5 border border-black {{ activite.couleur }}"></div>
                    <div>
                        <p class="text-sm font-medium text-gray-900">{{ activite.titre }}</p>
                        <p class="text-xs text-gray-500 mt-1">{{ activite.temps }}</p>
                    </div>
                </div>
                <div class="text-gray-400 group-hover:text-black transition-colors">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                    </svg>
                </div>
            </a>
            {% else %}
            <p class="text-xs text-gray-500 italic text-center py-6">Aucune activité récente enregistrée.</p>
            {% endfor %}
        </div>
    </div>

</div>
{% endblock %}