{% extends 'admin_base.html.twig' %}

{% block title %}Modifier l'utilisateur - Administration{% endblock %}
{% block header_title %}Modifier l'utilisateur{% endblock %}

{% block admin_content %}
<div class="lg:max-w-3xl">
	<div class="bg-white rounded-lg shadow-sm border border-slate-200 p-6 lg:p-8">

		<p class="text-sm text-slate-500 mb-8">
			Modifiez les informations de
			<span class="font-semibold text-slate-700">{{ edited_user.prenom }}
				{{ edited_user.nom }}</span>
			puis enregistrez vos changements.
		</p>

		{{ form_start(form, {'attr': {'class': 'space-y-5', 'novalidate': 'novalidate'}}) }}

		<div class="grid sm:grid-cols-2 gap-5">
			<div>
				<label class="block text-[11px] font-bold text-slate-500 uppercase tracking-wider mb-1.5"
					for="{{ form.prenom.vars.id }}">Prénom</label>
				{{ form_widget(form.prenom, {'attr': {'class': 'w-full px-4 py-2.5 border border-slate-300 bg-white
				text-black text-sm rounded-lg focus:outline-none focus:border-black transition-colors'}}) }}
				<div class="text-red-500 text-xs font-bold mt-1">{{ form_errors(form.prenom) }}</div>
			</div>
			<div>
				<label class="block text-[11px] font-bold text-slate-500 uppercase tracking-wider mb-1.5"
					for="{{ form.nom.vars.id }}">Nom</label>
				{{ form_widget(form.nom, {'attr': {'class': 'w-full px-4 py-2.5 border border-slate-300 bg-white
				text-black text-sm rounded-lg focus:outline-none focus:border-black transition-colors'}}) }}
				<div class="text-red-500 text-xs font-bold mt-1">{{ form_errors(form.nom) }}</div>
			</div>
		</div>

		<div>
			<label class="block text-[11px] font-bold text-slate-500 uppercase tracking-wider mb-1.5"
				for="{{ form.email.vars.id }}">Email</label>
			{{ form_widget(form.email, {'attr': {'class': 'w-full px-4 py-2.5 border border-slate-300 bg-white
			text-black text-sm rounded-lg focus:outline-none focus:border-black transition-colors'}}) }}
			<div class="text-red-500 text-xs font-bold mt-1">{{ form_errors(form.email) }}</div>
		</div>

		<div>
			{% if 'ROLE_ADMIN' in edited_user.roles %}
			{% do form.role.setRendered %}
			<p class="text-[11px] font-bold text-slate-500 uppercase tracking-wider mb-1.5">Rôle</p>
			<span class="inline-block bg-red-100 text-red-800 text-xs font-bold px-2.5 py-1 rounded">Admin</span>
			<p class="text-[11px] text-slate-400 mt-1.5">Le rôle administrateur ne peut pas être modifié depuis cette
				page.</p>
			{% else %}
			<label class="block text-[11px] font-bold text-slate-500 uppercase tracking-wider mb-1.5"
				for="{{ form.role.vars.id }}">Rôle</label>
			<div class="relative">
				{{ form_widget(form.role, {'attr': {'class': 'w-full px-4 py-2.5 pr-10 border border-slate-300 bg-white
				text-black text-sm rounded-lg focus:outline-none focus:border-black transition-colors
				appearance-none'}}) }}
				<svg class="w-4 h-4 text-slate-400 absolute right-3 top-1/2 -translate-y-1/2 pointer-events-none"
					fill="none" stroke="currentColor" viewbox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
				</svg>
			</div>
			{% endif %}
		</div>
		{% if edited_user.classes is not empty %}
		<div>
			<p class="text-[11px] font-bold text-slate-500 uppercase tracking-wider mb-1.5">Classes</p>
			<div class="flex flex-wrap gap-2">
				{% for classe in edited_user.classes %}
				<span class="bg-slate-100 text-slate-700 text-xs font-bold px-2.5 py-1 rounded">{{ classe.nom }}</span>
				{% endfor %}
			</div>
			<p class="text-[11px] text-slate-400 mt-1.5">La gestion des étudiants d'une classe se fait depuis la fiche
				de la classe.</p>
		</div>
		{% endif %}

		<button type="submit"
			class="w-full sm:w-auto bg-black hover:bg-slate-800 text-white font-bold py-3 px-8 rounded-lg transition-colors text-sm">
			Enregistrer les modifications
		</button>

		<div class="border-t border-slate-200 pt-6 mt-8">
			<label class="flex items-start gap-3 cursor-pointer">
				{{ form_widget(form.isArchived, {'attr': {'class': 'mt-0.5 w-4 h-4 accent-red-600'}}) }}
				<span>
					<span class="block text-xs font-bold text-red-600 uppercase tracking-wider">Archiver ce
						compte</span>
					<span class="block text-xs text-slate-500 mt-0.5">Le compte ne pourra plus se connecter et sera
						masqué des listes.</span>
				</span>
			</label>
			{{ form_errors(form.isArchived) }}
		</div>

		{{ form_end(form) }}
	</div>

	<div class="text-center mt-6">
		<a href="{{ path('app_admin_users') }}"
			class="text-xs font-bold text-slate-500 hover:text-black uppercase tracking-wider transition-colors">
			Annuler et retourner à la liste
		</a>
	</div>
</div>
{% endblock %}