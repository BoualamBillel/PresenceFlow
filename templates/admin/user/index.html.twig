{% extends 'admin_base.html.twig' %}

{% block title %}Utilisateurs - Administration{% endblock %}
{% block header_title %}Utilisateurs{% endblock %}

{% block admin_content %}
<div class="max-w-7xl mx-auto w-full bg-white min-h-screen p-4 sm:p-6 lg:p-8 pb-24">

    <p class="text-sm text-gray-800 mb-6 font-medium">Gérez les profils et les accès de votre établissement.</p>

    {# --- HEADER RESPONSIVE --- #}
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 mb-6">

        {# --- BARRE DE RECHERCHE --- #}
        <form method="GET" action="{{ path('app_admin_users') }}" class="relative w-full md:w-1/2 lg:w-1/3">
            <input type="hidden" name="filter" value="{{ currentFilter }}">

            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                </svg>
            </div>

            <input type="text" name="q" value="{{ currentSearch }}" placeholder="RECHERCHER PAR NOM, EMAIL..."
                class="w-full pl-10 pr-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-black focus:border-black text-xs font-bold tracking-widest uppercase placeholder-gray-400 transition-shadow"
                onchange="this.form.submit()">
        </form>

        {# --- BOUTON D'AJOUT --- #}
        <a href="{{ path('app_user_new') }}"
            class="w-full md:w-auto bg-black text-white px-6 py-3.5 flex items-center justify-center space-x-3 hover:bg-gray-800 transition-colors rounded-lg shadow-md flex-shrink-0">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
            </svg>
            <span class="text-xs font-bold tracking-widest uppercase">Nouvel Utilisateur</span>
        </a>
    </div>

    {# --- FILTRES (Pills) --- #}
    <div
        class="flex space-x-2 overflow-x-auto pb-2 mb-6 scrollbar-hide md:flex-wrap md:overflow-visible md:pb-0 md:gap-y-2">
        <a href="{{ path('app_admin_users', {filter: 'tous', q: currentSearch}) }}"
            class="px-4 py-1.5 text-xs font-bold rounded-full whitespace-nowrap transition-colors shadow-sm {{ currentFilter == 'tous' ? 'bg-black text-white' : 'bg-white border border-gray-300 text-gray-600 hover:bg-gray-50' }}">
            Tous
        </a>
        <a href="{{ path('app_admin_users', {filter: 'formateurs', q: currentSearch}) }}"
            class="px-4 py-1.5 text-xs font-bold rounded-full whitespace-nowrap transition-colors shadow-sm {{ currentFilter == 'formateurs' ? 'bg-black text-white' : 'bg-white border border-gray-300 text-gray-600 hover:bg-gray-50' }}">
            Formateurs
        </a>
        <a href="{{ path('app_admin_users', {filter: 'apprenants', q: currentSearch}) }}"
            class="px-4 py-1.5 text-xs font-bold rounded-full whitespace-nowrap transition-colors shadow-sm {{ currentFilter == 'apprenants' ? 'bg-black text-white' : 'bg-white border border-gray-300 text-gray-600 hover:bg-gray-50' }}">
            Apprenants
        </a>
        <a href="{{ path('app_admin_users', {filter: 'archives', q: currentSearch}) }}"
            class="px-4 py-1.5 text-xs font-bold rounded-full whitespace-nowrap transition-colors shadow-sm {{ currentFilter == 'archives' ? 'bg-black text-white' : 'bg-white border border-gray-300 text-gray-600 hover:bg-gray-50' }}">
            Archivés
        </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">

        {% for user in users %}
        {% set initials = (user.prenom|first|default(''))|upper ~ (user.nom|first|default(''))|upper %}

        {% if 'ROLE_ADMIN' in user.roles %}
        {% set roleBadge = 'Admin' %}
        {% set colorClass = 'bg-red-100 text-red-800' %}
        {% set infoText = 'Administration' %}
        {% elseif 'ROLE_FORMATEUR' in user.roles %}
        {% set roleBadge = 'Formateur' %}
        {% set colorClass = 'bg-stone-200 text-stone-800' %}
        {% set infoText = 'Équipe pédagogique' %}
        {% else %}
        {% set roleBadge = 'Apprenant' %}
        {% set colorClass = 'bg-blue-100 text-blue-800' %}
        {% set firstClasse = user.classes|first %}
        {% set infoText = firstClasse ? firstClasse.nom : 'Sans affectation' %}
        {% endif %}

        <div
            class="flex items-center justify-between p-4 border border-gray-200 rounded-xl bg-white shadow-sm hover:shadow-md hover:border-gray-300 transition-all cursor-pointer group">

            <div class="flex items-center space-x-4 min-w-0 w-full">

                <div
                    class="w-10 h-10 flex-shrink-0 rounded-full {{ colorClass }} flex items-center justify-center text-xs font-black uppercase">
                    {{ initials }}
                </div>

                <div class="min-w-0 flex-1 pr-2">
                    <h3 class="text-sm font-bold text-black truncate" title="{{ user.prenom }} {{ user.nom }}">{{
                        user.prenom }} {{ user.nom }}</h3>
                    <p class="text-[11px] text-gray-500 font-medium truncate" title="{{ roleBadge }} • {{ infoText }}">
                        {{ roleBadge }} • {{ infoText }}</p>
                </div>
            </div>

            <svg class="w-5 h-5 flex-shrink-0 text-gray-300 group-hover:text-black transition-colors" fill="none"
                stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
        </div>

        {% else %}
        <div
            class="col-span-full p-12 bg-gray-50 rounded-xl border border-dashed border-gray-300 text-center text-gray-500 text-sm font-bold">
            <svg class="w-10 h-10 mx-auto mb-3 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4">
                </path>
            </svg>
            Aucun utilisateur enregistré pour le moment.
        </div>
        {% endfor %}

    </div>

    {# --- CHARGER PLUS --- #}
    {% if hasMore %}
    <div class="text-center mt-8">
        <a href="{{ path('app_admin_users', {'limit': currentLimit + 10, 'filter': currentFilter, 'q': currentSearch}) }}"
            class="text-xs font-bold text-slate-600 hover:text-black transition-colors inline-block py-3 px-6 rounded-lg bg-gray-100 hover:bg-gray-200">
            Charger plus d'utilisateurs
        </a>
    </div>
    {% elseif users|length > 0 %}
    <div class="text-center mt-8">
        <span class="text-xs font-medium text-gray-400 bg-gray-50 py-2 px-4 rounded-full">Tous les utilisateurs sont
            affichés.</span>
    </div>
    {% endif %}

</div>
{% endblock %}