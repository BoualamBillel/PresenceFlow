{% extends 'admin_base.html.twig' %}

{% block title %}Justifications - Administration{% endblock %}

{% block admin_content %}

<div class="max-w-md mx-auto bg-white min-h-screen lg:max-w-none lg:mx-0 lg:bg-transparent lg:min-h-0">

    <div class="p-4 lg:p-0 lg:max-w-6xl lg:mx-auto">
        <p class="text-sm font-medium text-slate-700 mb-4 lg:mb-6">Examinez et validez les motifs d'absence.</p>

        {# Système d'onglets dynamique #}
        <div class="flex justify-center mb-6 lg:mb-8">
            <div class="inline-flex rounded-lg border border-black p-0.5 w-64 bg-gray-200">

                {# Onglet EN ATTENTE #}
                <a href="{{ path('admin_justificatif_index', {filter: 'en_attente'}) }}"
                    class="flex-1 text-center py-1.5 text-xs font-bold transition-all rounded-md {{ current_filter == 'en_attente' ? 'bg-[#1a1a1a] text-white shadow' : 'text-gray-700 hover:text-black' }}">
                    En attente
                </a>

                {# Onglet TRAITÉS #}
                <a href="{{ path('admin_justificatif_index', {filter: 'traites'}) }}"
                    class="flex-1 text-center py-1.5 text-xs font-bold transition-all rounded-md {{ current_filter == 'traites' ? 'bg-[#1a1a1a] text-white shadow' : 'text-gray-700 hover:text-black' }}">
                    Traités
                </a>

            </div>
        </div>

        {# Liste des justificatifs #}
        <div class="space-y-4 pb-20 lg:pb-0 lg:space-y-0 lg:grid lg:grid-cols-2 xl:grid-cols-3 lg:gap-6">
            {% for justificatif in justificatifs %}

            {# Carte individuelle #}
            <div class="border border-slate-300 rounded-lg p-4 bg-white shadow-sm lg:transition-shadow lg:hover:shadow-md">

                {# Étudiant #}
                <div class="text-center mb-3">
                    <h2 class="text-base font-medium text-slate-900">{{ justificatif.emargement.etudiant.prenom }} {{
                        justificatif.emargement.etudiant.nom }}</h2>
                    <p class="text-sm text-slate-600">
                        {% if justificatif.emargement.etudiant.classes is not empty %}
                        {{ justificatif.emargement.etudiant.classes|first.nom }} - Promo {{
                        justificatif.emargement.etudiant.classes|first.annee }}
                        {% else %}
                        Classe / Promo inconnue
                        {% endif %}
                    </p>
                </div>

                {# Badge Absence #}
                <div class="border border-slate-200 rounded-lg py-2 mb-3 flex items-center justify-center space-x-2">
                    <span class="text-xs">🔴</span>
                    <span class="font-bold text-sm text-slate-900">Absence le {{
                        justificatif.emargement.session.dateCours|date('d M.') }}</span>
                </div>

                {# Pièce jointe #}
                <div class="flex justify-center mb-3">
                    {% if justificatif.urlFichier %}
                    <a href="{{ asset('uploads/justificatifs/' ~ justificatif.urlFichier) }}" target="_blank"
                        class="border border-slate-300 rounded-lg px-4 py-1.5 flex items-center space-x-2 text-sm text-slate-700 hover:bg-slate-50">
                        <svg class="w-4 h-4 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414A1 1 0 01.293.707V19a2 2 0 01-2 2z">
                            </path>
                        </svg>
                        <span>Voir la pièce jointe</span>
                    </a>
                    {% else %}
                    <div class="flex items-center space-x-2 text-sm text-slate-500">
                        <svg class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z">
                            </path>
                        </svg>
                        <span>Aucun document fourni</span>
                    </div>
                    {% endif %}
                </div>

                {# Motif de l'étudiant #}
                <div class="text-center mb-4 px-2">
                    <p class="text-sm text-slate-700">"{{ justificatif.motifAbsence }}"</p>
                </div>

                {# Zone d'action ou de statut #}
                {% if justificatif.statut == constant('App\\Enum\\JustificatifStatut::EN_ATTENTE') %}
                <div class="flex justify-between gap-3">
                    <button type="button" onclick="openModal('modal-refus-{{ justificatif.id }}')"
                        class="w-1/2 py-1.5 border border-slate-300 rounded-lg text-sm font-bold text-slate-900 hover:bg-slate-50 text-center">
                        Refuser
                    </button>
                    <form action="{{ path('admin_justificatif_valider', {id: justificatif.id}) }}" method="POST"
                        class="w-1/2 m-0">
                        <input type="hidden" name="_token" value="{{ csrf_token('valider' ~ justificatif.id) }}">
                        <button type="submit"
                            class="w-full py-1.5 border border-slate-300 rounded-lg text-sm font-bold text-slate-900 hover:bg-slate-50 text-center">
                            Valider
                        </button>
                    </form>
                </div>
                {% else %}
                {# Affichage du badge de statut pour les éléments traités #}
                <div
                    class="text-center py-2 border rounded-lg {{ justificatif.statut == constant('App\\Enum\\JustificatifStatut::VALIDE') ? 'border-green-300 bg-green-50' : 'border-red-300 bg-red-50' }}">
                    <span
                        class="text-sm font-bold tracking-wide {{ justificatif.statut == constant('App\\Enum\\JustificatifStatut::VALIDE') ? 'text-green-700' : 'text-red-700' }}">
                        {{ justificatif.statut.label }}
                    </span>
                </div>

                {# Affichage du motif de refus rédigé par l'admin #}
                {% if justificatif.statut == constant('App\\Enum\\JustificatifStatut::REFUSE') and justificatif.motifRefus %}
                <div class="mt-3 text-center px-2 py-2 bg-slate-100 rounded-lg border border-slate-200">
                    <p class="text-xs font-bold text-slate-600 uppercase mb-1">Motif du refus :</p>
                    <p class="text-sm text-slate-700 italic">"{{ justificatif.motifRefus }}"</p>
                </div>
                {% endif %}
                {% endif %}
            </div>

            {# --- LA MODALE DE REFUS --- #}
            <div id="modal-refus-{{ justificatif.id }}"
                class="hidden fixed inset-0 bg-black/50 backdrop-blur-sm flex items-center justify-center z-50 p-4 transition-opacity duration-300">

                <div
                    class="bg-white p-6 rounded-2xl w-full max-w-sm shadow-2xl border border-slate-200 transform transition-all scale-100">

                    <h3 class="font-black text-center text-slate-900 mb-1 text-lg tracking-tight">Refuser le justificatif
                    </h3>
                    <p class="text-sm text-center text-slate-500 mb-6 font-medium">Veuillez expliquer à l'étudiant la
                        raison de ce refus.</p>

                    <form action="{{ path('admin_justificatif_refuser', {id: justificatif.id}) }}" method="POST">
                        <input type="hidden" name="_token" value="{{ csrf_token('refuser' ~ justificatif.id) }}">

                        <div class="mb-6">
                            <label class="block font-bold mb-2 text-xs text-slate-700 uppercase tracking-widest">Raison
                                du refus</label>

                            <textarea name="motif_refus" required rows="3"
                                class="w-full p-3 bg-white border border-slate-300 rounded-lg focus:border-black focus:outline-none text-sm text-slate-700 transition-shadow resize-none"
                                placeholder="Ex : Le document fourni est illisible..."></textarea>
                        </div>

                        <div class="flex gap-3">
                            <button type="button" onclick="closeModal('modal-refus-{{ justificatif.id }}')"
                                class="w-1/2 py-2.5 font-bold text-slate-900 bg-gray-100 rounded-xl text-sm text-center hover:bg-gray-200 transition-colors">
                                Annuler
                            </button>

                            <button type="submit"
                                class="w-1/2 bg-black text-white font-bold py-2.5 rounded-xl text-sm text-center shadow-md hover:bg-gray-800 hover:shadow-lg transition-all transform hover:-translate-y-0.5">
                                Confirmer
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            {% else %}
            {# État vide #}
            <div class="p-8 text-center border border-dashed border-slate-300 rounded-lg lg:col-span-full">
                <p class="text-sm font-medium text-slate-500">Aucun justificatif en attente.</p>
            </div>
            {% endfor %}
        </div>
    </div>
</div>

{# Script modale #}
<script>
    function openModal(modalId) {
        document.getElementById(modalId).classList.remove('hidden');
    }
    function closeModal(modalId) {
        document.getElementById(modalId).classList.add('hidden');
    }
</script>
{% endblock %}