<!DOCTYPE html>
<html lang="fr">
	<head>
		<meta charset="UTF-8">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
		<title>{{ block('code') }}
			- PresenceFlow</title>
		<script src="https://cdn.tailwindcss.com"></script>
	</head>
	<body class="bg-gray-50 min-h-screen flex items-center justify-center p-6 font-sans">

		{% if is_granted('ROLE_ADMIN') %}
			{% set accueil = path('app_session_cours_index') %}
		{% elseif is_granted('ROLE_FORMATEUR') %}
			{% set accueil = path('app_formateur_dashboard') %}
		{% elseif app.user %}
			{% set accueil = path('app_etudiant_dashboard') %}
		{% else %}
			{% set accueil = path('app_login') %}
		{% endif %}

		<main class="w-full max-w-md text-center">

			<div class="w-16 h-16 bg-white text-black border-2 border-black rounded-lg flex items-center justify-center mx-auto mb-8 shadow-sm">
				{% block error_icon %}
					<svg class="w-8 h-8" fill="none" stroke="currentColor" viewbox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
					</svg>
				{% endblock %}
			</div>

			<p class="text-7xl font-black text-black tracking-tight mb-2">
				{% block code %}
					{{ status_code }}
				{% endblock %}
			</p>

			<h1 class="text-[13px] font-bold text-black border-b-[2px] border-black inline-block pb-1 px-4 uppercase tracking-widest mb-5">
				{% block error_title %}Une erreur est survenue
				{% endblock %}
			</h1>

			<p class="text-xs text-slate-500 leading-relaxed font-medium mb-10">
				{% block error_message %}Quelque chose s'est mal passé de notre côté. Réessayez dans quelques instants.
				{% endblock %}
			</p>

			<a href="{{ accueil }}" class="block w-full bg-black hover:bg-slate-800 text-white font-bold py-4 rounded-lg text-xs uppercase tracking-widest transition-colors">
				Retour à l'accueil
			</a>

			{% block extra_actions %}{% endblock %}

			<button type="button" onclick="history.back()" class="mt-4 text-[11px] font-bold text-slate-500 hover:text-black uppercase tracking-wider transition-colors">
				Retour à la page précédente
			</button>

		</main>

	</body>
</html>