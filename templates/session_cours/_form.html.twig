{{ form_start(form, {'attr': {'class': 'space-y-4', 'novalidate': 'novalidate'}}) }}

    {% macro select_field(field) %}
        <div>
            {{ form_label(field, null, {'label_attr': {'class': 'block text-[10px] font-bold text-black uppercase tracking-wider mb-1'}}) }}
            <div class="relative">
                {{ form_widget(field, {'attr': {'class': 'appearance-none w-full px-3 py-3 border border-gray-400 bg-white text-black focus:outline-none focus:border-black text-sm rounded-none cursor-pointer'}}) }}
                <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-4 text-black">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                </div>
            </div>
            <div class="text-red-500 text-xs font-bold mt-1">{{ form_errors(field) }}</div>
        </div>
    {% endmacro %}

    {# Nom de la matière #}
    {{ _self.select_field(form.matiere) }}

    {# Date du cours #}
    <div>
        {{ form_label(form.dateCours, null, {'label_attr': {'class': 'block text-[10px] font-bold text-black uppercase tracking-wider mb-1'}}) }}
        {{ form_widget(form.dateCours, {'attr': {'class': 'w-full px-3 py-3 border border-gray-400 bg-white text-black focus:outline-none focus:border-black text-sm rounded-none'}}) }}
        <div class="text-red-500 text-xs font-bold mt-1">{{ form_errors(form.dateCours) }}</div>
    </div>

    {# Bloc Heures #}
    <div class="grid grid-cols-2 gap-4">
        <div>
            {{ form_label(form.heureDebut, null, {'label_attr': {'class': 'block text-[10px] font-bold text-black uppercase tracking-wider mb-1'}}) }}
            {{ form_widget(form.heureDebut, {'attr': {'class': 'w-full px-3 py-3 border border-gray-400 bg-white text-black focus:outline-none focus:border-black text-sm rounded-none'}}) }}
            <div class="text-red-500 text-xs font-bold mt-1">{{ form_errors(form.heureDebut) }}</div>
        </div>
        <div>
            {{ form_label(form.heureFin, null, {'label_attr': {'class': 'block text-[10px] font-bold text-black uppercase tracking-wider mb-1'}}) }}
            {{ form_widget(form.heureFin, {'attr': {'class': 'w-full px-3 py-3 border border-gray-400 bg-white text-black focus:outline-none focus:border-black text-sm rounded-none'}}) }}
            <div class="text-red-500 text-xs font-bold mt-1">{{ form_errors(form.heureFin) }}</div>
        </div>
    </div>

    {# Classe rattachée #}
    {{ _self.select_field(form.classe) }}

    {# Formateur #}
    {{ _self.select_field(form.formateur) }}

    {# Salle / Emplacement #}
    <div>
        {{ form_label(form.emplacement, null, {'label_attr': {'class': 'block text-[10px] font-bold text-black uppercase tracking-wider mb-1'}}) }}
        {{ form_widget(form.emplacement, {'attr': {'class': 'w-full px-3 py-3 border border-gray-400 bg-white text-black focus:outline-none focus:border-black text-sm rounded-none focus:placeholder-transparent'}}) }}
        <div class="text-red-500 text-xs font-bold mt-1">{{ form_errors(form.emplacement) }}</div>
    </div>

    {# Tolérance (Optionnelle - Masquée du visuel principal) #}
    <div class="hidden">
        {{ form_widget(form.toleranceRetard, {'value': 0}) }}
    </div>

    <hr class="border-gray-200 mt-6 mb-4">

    <button type="submit" class="w-full bg-[#0a0a0a] hover:bg-black text-white font-bold py-4 rounded-xl transition-colors text-sm">
        {{ button_label|default('Créer la session') }}
    </button>

{{ form_end(form) }}