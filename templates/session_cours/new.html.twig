{% extends 'admin_base.html.twig' %}

{% block title %}Nouvelle Session - Administration{% endblock %}
{% block header_title %}Planification{% endblock %}

{% block admin_content %}
    <div class="w-full max-w-xl mx-auto flex flex-col">
        
        <div class="mb-6 mt-2">
            <p class="text-sm font-medium text-slate-700">Planifiez une nouvelle session de cours.</p>
        </div>

        <div class="bg-white border border-slate-200 rounded-2xl p-5 sm:p-8 shadow-sm">
            {{ include('session_cours/_form.html.twig') }}
        </div>
        
        <div class="text-center mt-4 mb-8">
            <a href="{{ path('app_session_cours_index') }}" class="text-xs font-bold text-slate-500 hover:text-black uppercase tracking-wider">
                Annuler la planification
            </a>
        </div>

    </div>
{% endblock %}