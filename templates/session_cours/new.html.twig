{% extends 'admin_base.html.twig' %}

{% block title %}Nouvelle Session - Administration{% endblock %}
{% block header_title %}Planification{% endblock %}

{% block admin_content %}
    <div class="bg-white px-6 py-8 rounded-t-3xl sm:rounded-3xl shadow-sm border border-slate-200 min-h-[75vh]">
        
        <div class="w-12 h-1.5 bg-gray-200 rounded-full mx-auto mb-8"></div>

        <div class="mb-6 inline-block">
            <h2 class="text-xl font-black text-black tracking-tight mb-1">Nouvelle Session</h2>
            <div class="h-0.5 w-full bg-black"></div>
        </div>

        {{ include('session_cours/_form.html.twig') }}
        
    </div>
    
    <div class="text-center mt-4 mb-8">
        <a href="{{ path('app_session_cours_index') }}" class="text-xs font-bold text-slate-500 hover:text-black uppercase tracking-wider">
            Annuler la planification
        </a>
    </div>
{% endblock %}